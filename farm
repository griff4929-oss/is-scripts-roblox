-- =========================
-- FUNCIÓN VERIFICAR SI EXISTE UNA TORRE EN LA CARPETA TOWERS
-- =========================

local function towerExists(towerName)
	local towers = WS:FindFirstChild("Towers")
	if not towers then return false end
	
	for _, tower in pairs(towers:GetChildren()) do
		local config = tower:FindFirstChild("Config")
		if config and config:FindFirstChild("Owner") and config.Owner.Value == LocalPlayer.Name then
			local tName = config:FindFirstChild("TowerName")
			if tName and tName.Value == towerName then
				return true
			end
		end
	end
	return false
end

