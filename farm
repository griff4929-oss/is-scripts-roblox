local function startFarm1()
	if farm1Active then return end
	farm1Active = true
	saveState()
	updateFarm1UI()
	
	task.spawn(function()
		local bunnyCFrame = CFrame.new(-25.735321, 86.0418549, -85.5302887)
		local waitTime = 16
		
		while farm1Active do
			pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame) end)
			for i = 1, waitTime do
				if not farm1Active then break end
				task.wait(1)
			end
			if waitTime > 5 then waitTime = waitTime - 1 end
		end
	end)
	
	task.spawn(function()
		while farm1Active do
			pcall(function() RS.Events.VoteSkip:FireServer() end)
			task.wait(0.5)
		end
	end)
end

local function stopFarm1()
	if not farm1Active then return end
	farm1Active = false
	saveState()
	updateFarm1UI()
end

-- =========================
-- FARM 2
-- =========================

local function startFarm2()
	if farm2Active then return end
	farm2Active = true
	saveState2()
	updateFarm2UI()
	
	task.spawn(function()
		local bunnyCFrame = CFrame.new(29.8349686, 84.2882462, -17.7190742)
		local mechCFrame = CFrame.new(7.5827179, 88.5881958, -28.159481)
		local titanCFrame = CFrame.new(4.03090668, 89.2408905, -1.34775352)
		local scientistCFrame = CFrame.new(41.5543137, 82.593399, -44.0053787)
		
		for i = 1, 4 do
			pcall(function() RS.Functions.SpawnTower:InvokeServer("Scientist Cameraman", scientistCFrame) end)
			task.wait(0.3)
		end
		
		while farm2Active do
			local bunnyWait = 11
			local startTime = tick()
			while farm2Active and (tick() - startTime) < 60 do
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame) end)
				for i = 1, bunnyWait do
					if not farm2Active then break end
					task.wait(1)
				end
				if bunnyWait > 5 then bunnyWait = bunnyWait - 1 end
			end
			
			if not farm2Active then break end
			
			local mechStart = tick()
			while farm2Active and (tick() - mechStart) < 120 do
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Mech Cameraman", mechCFrame) end)
				for i = 1, 3 do
					if not farm2Active then break end
					task.wait(1)
				end
			end
			
			if not farm2Active then break end
			
			venderTodosLosBunnies()
			spawnSpeakerwoman()
			
			while farm2Active do
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Titan Cinemaman", titanCFrame) end)
				for i = 1, 30 do
					if not farm2Active then break end
					task.wait(1)
				end
			end
		end
		
		exitGame()
	end)
	
	task.spawn(function()
		while farm2Active do
			pcall(function() RS.Events.VoteSkip:FireServer() end)
			task.wait(0.5)
		end
	end)
end

