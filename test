local function saveState(mode, value)
    local fileName = "GriffHub_" .. mode .. "_" .. LocalPlayer.UserId .. ".json"
    local data = { active = value }
    pcall(function()
        if writefile then
            writefile(fileName, HttpService:JSONEncode(data))
        end
    end)
end

local function loadState(mode)
    local fileName = "GriffHub_" .. mode .. "_" .. LocalPlayer.UserId .. ".json"
    local success, content = pcall(function()
        if readfile then return readfile(fileName) end
    end)
    if success and content then
        local success2, data = pcall(function()
            return HttpService:JSONDecode(content)
        end)
        if success2 and data then return data.active or false end
    end
    return false
end

