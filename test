-- =========================
-- BLOQUEAR NOTIFICACIONES DE ERROR
-- =========================

local TextEvent = RS:FindFirstChild("Events") and RS.Events:FindFirstChild("TextEvent")

if TextEvent then
    local success, connections = pcall(function()
        return getconnections(TextEvent.OnClientEvent)
    end)
    
    if success and connections then
        for _, conn in ipairs(connections) do
            pcall(function() conn:Disable() end)
        end
    end
    
    local oldEvent = TextEvent.OnClientEvent
    TextEvent.OnClientEvent = Instance.new("BindableEvent").Event
    
    TextEvent.OnClientEvent:Connect(function(typ, text)
        if typ == "Error" then
            return
        end
        if oldEvent then
            oldEvent(typ, text)
        end
    end)
end

