				task.wait(0.5)
			end
		end)
		
		statusLabel3.Text = "💀 Spawneando Bunny cada 8s..."
		timerLabel3.Text = "⏱️ Fase: INSANE"
		timerLabel3.TextColor3 = Color3.fromRGB(255, 50, 50)
		
		local bunnyCount = 0
		local mechCount = 0
		local lastMechTime = tick()
		
		while farm3Active do
			spawnTimeLabel3.Text = "🐰 Bunny en 8s | 🤖 Mech en " .. math.max(0, 60 - (tick() - lastMechTime)) .. "s"
			timerLabel3.Text = "⏱️ BUNNY: CADA 8s"
			
			local waited = 0
			while farm3Active and waited < 8 do
				task.wait(1)
				waited = waited + 1
				local mechTimeLeft = math.max(0, 60 - (tick() - lastMechTime))
				spawnTimeLabel3.Text = "🐰 Bunny en " .. (8 - waited) .. "s | 🤖 Mech en " .. math.floor(mechTimeLeft) .. "s"
			end
			
			if farm3Active then
				-- Spawn Bunny
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame) end)
				bunnyCount = bunnyCount + 1
				statusLabel3.Text = "💀 Bunny #" .. bunnyCount
				
				-- Spawn Mech cada 60 segundos
				if tick() - lastMechTime >= 60 then
					pcall(function() RS.Functions.SpawnTower:InvokeServer("Mech Cameraman", mechCFrame) end)
					mechCount = mechCount + 1
					lastMechTime = tick()
					statusLabel3.Text = "💀 Bunny #" .. bunnyCount .. " | Mech #" .. mechCount
				end
			end
		end
	end)
end

