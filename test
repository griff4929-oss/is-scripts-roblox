local function savePremiumStatus()
    pcall(function()
        if writefile then
            writefile(SaveFileName, "true")
        end
    end)
end

local function loadPremiumStatus()
    local success, content = pcall(function()
        if readfile then
            return readfile(SaveFileName)
        end
    end)
    return success and content == "true"
end

