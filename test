        farmActive = true
        
        task.spawn(function()
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(21.937172, 5.037024, -161.283066))
