-- =========================
-- FUNCIONES DE AUTOFARM
-- =========================

local function mejorarUnidad(nombreUnidad)
    local functions = RS:FindFirstChild("Functions")
    local spawnTower = functions and functions:FindFirstChild("SpawnTower")
    if not spawnTower then return end
    
    local towers = WS:FindFirstChild("Towers")
    if not towers then return end
    
    for _, torre in pairs(towers:GetChildren()) do
        local config = torre:FindFirstChild("Config")
        if config and config:FindFirstChild("Owner") and config.Owner.Value == LocalPlayer.Name then
            local nombre = config:FindFirstChild("TowerName")
            local upgrade = config:FindFirstChild("Upgrade")
            if nombre and nombre.Value == nombreUnidad and upgrade and upgrade.Value then
                pcall(function()
                    spawnTower:InvokeServer(upgrade.Value.Name, torre.PrimaryPart.CFrame, torre)
                end)
            end
        end
    end
end

local function venderTodosLosBunnies()
    local sellTower = RS.Events:FindFirstChild("SellTower") or RS.Functions:FindFirstChild("SellTower")
    if not sellTower then return 0 end
    
    local towers = WS:FindFirstChild("Towers")
    if not towers then return 0 end
    
    local vendidos = 0
    for _, tower in pairs(towers:GetChildren()) do
        local config = tower:FindFirstChild("Config")
        if config and config:FindFirstChild("Owner") and config.Owner.Value == LocalPlayer.Name then
            local tName = config:FindFirstChild("TowerName")
            if tName and (tName.Value == "Large Bunny TV Man" or tName.Value == "Bunny TV Man") then
                pcall(function() sellTower:InvokeServer(tower) end)
                vendidos = vendidos + 1
            end
        end
    end
    return vendidos
end

-- =========================
-- NIGHTMARE
-- =========================

local function stopNightmare()
    if not nightmareActive then return end
    nightmareActive = false
    saveState()
    
    if farmTasks.nightmare then
        task.cancel(farmTasks.nightmare)
        farmTasks.nightmare = nil
    end
    
    -- Actualizar UI si existe
    if nightmareToggleUI then
        pcall(function() nightmareToggleUI:Set(false) end)
    end
    
    print("❌ Nightmare DESACTIVADO")
    OrionLib:MakeNotification({
        Name = "Nightmare",
        Content = "AutoFarm desactivado",
        Time = 2
    })
end

local function startNightmare()
    if nightmareActive then return end
    nightmareActive = true
    saveState()
    
    -- Actualizar UI si existe
    if nightmareToggleUI then
        pcall(function() nightmareToggleUI:Set(true) end)
    end
    
    print("✅ Nightmare ACTIVADO")
    OrionLib:MakeNotification({
        Name = "Nightmare",
        Content = "AutoFarm activado en Elevator16",
        Time = 2
    })
    
    farmTasks.nightmare = task.spawn(function()
        -- Enviar eventos
        local argsEnter = { [1] = "Elevator16" }
        local argsStart = { [1] = "Elevator16" }
        
        pcall(function() 
            RS.Events.EnterElevator:FireServer(unpack(argsEnter))
        end)
        pcall(function() 
            RS.Events.StartElevator:FireServer(unpack(argsStart))
        end)
        
        if not nightmareActive then return end
        
        local bunnyCFrame = CFrame.new(-25.735321, 86.0418549, -85.5302887)
        local titanCFrame = CFrame.new(-47.0388031, 90.3418045, -86.8553925)
        
        -- VoteSkip loop
        task.spawn(function()
            while nightmareActive do
                pcall(function() RS.Events.VoteSkip:FireServer() end)
                task.wait(0.05)
            end
        end)
        
        -- Mejorar unidades loop
        task.spawn(function()
            while nightmareActive do
                mejorarUnidad("Large Bunny TV Man")
                mejorarUnidad("Upgraded Titan Cameraman")
                task.wait(0.3)
            end
        end)
        
        -- Fase Bunny (60 segundos)
        currentWaitTime = 16
        local bunnyStartTime = tick()
        
        while nightmareActive and (tick() - bunnyStartTime) < 60 do
            local waited = 0
            while nightmareActive and waited < currentWaitTime and (tick() - bunnyStartTime) < 60 do
                task.wait(1)
                waited = waited + 1
            end
            
            if nightmareActive and (tick() - bunnyStartTime) < 60 then
                pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame) end)
                if currentWaitTime > minWaitTime then
                    currentWaitTime = math.max(minWaitTime, currentWaitTime - 1)
                end
            end
        end
        
        if not nightmareActive then return end
        
        -- Fase Titan (infinita)
        currentWaitTime = 16
        
        while nightmareActive do
            local waited = 0
            while nightmareActive and waited < currentWaitTime do
                task.wait(1)
                waited = waited + 1
            end
            
            if nightmareActive then
                pcall(function() RS.Functions.SpawnTower:InvokeServer("Upgraded Titan Cameraman", titanCFrame) end)
                if currentWaitTime > minWaitTime then
                    currentWaitTime = math.max(minWaitTime, currentWaitTime - 1)
                end
            end
        end
    end)
end

