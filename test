-- =========================
-- GRIFF HUB - FUN PAGE (SOLO VISUAL)
-- =========================

-- Servicios
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- =========================
-- CREAR GUI
-- =========================

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GriffHub"
screenGui.ResetOnSpawn = false
screenGui.Parent = CoreGui

-- Botón toggle (abrir/cerrar)
local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.Size = UDim2.new(0, 100, 0, 40)
toggleBtn.Position = UDim2.new(0, 20, 0.15, 0)
toggleBtn.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 14
toggleBtn.Text = "🥚 Griff Hub"
toggleBtn.BorderSizePixel = 0
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 8)

-- Frame principal
local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size = UDim2.new(0, 300, 0, 400)
mainFrame.Position = UDim2.new(0.35, 0, 0.2, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
mainFrame.BorderSizePixel = 0
mainFrame.Visible = false
mainFrame.Active = true
mainFrame.Draggable = true
Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 12)

-- Header
local header = Instance.new("Frame", mainFrame)
header.Size = UDim2.new(1, 0, 0, 44)
header.Position = UDim2.new(0, 0, 0, 0)
header.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
header.BorderSizePixel = 0
Instance.new("UICorner", header).CornerRadius = UDim.new(0, 12)

local title = Instance.new("TextLabel", header)
title.Size = UDim2.new(1, -20, 1, 0)
title.Position = UDim2.new(0, 10, 0, 0)
title.BackgroundTransparency = 1
title.TextColor3 = Color3.new(1, 1, 1)
title.Font = Enum.Font.GothamBold
title.TextSize = 18
title.Text = "🥚 Griff Hub"
title.TextXAlignment = Enum.TextXAlignment.Left

-- Botón de cerrar
local closeBtn = Instance.new("TextButton", header)
closeBtn.Size = UDim2.new(0, 30, 0, 30)
closeBtn.Position = UDim2.new(1, -35, 0, 7)
closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
closeBtn.TextColor3 = Color3.new(1, 1, 1)
closeBtn.Font = Enum.Font.GothamBold
closeBtn.TextSize = 14
closeBtn.Text = "X"
closeBtn.BorderSizePixel = 0
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)

closeBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
end)

toggleBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = not mainFrame.Visible
end)

-- =========================
-- FUN PAGE
-- =========================

-- Variables de estado
local invAutoSellEnabled = false
local summonAutoSellEnabled = false
local signEnabled = false

-- Frame para los botones
local buttonsFrame = Instance.new("Frame", mainFrame)
buttonsFrame.Size = UDim2.new(1, -20, 1, -60)
buttonsFrame.Position = UDim2.new(0, 10, 0, 55)
buttonsFrame.BackgroundTransparency = 1

-- Función para crear botones
local function createButton(yPos, text, color)
    local btn = Instance.new("TextButton", buttonsFrame)
    btn.Size = UDim2.new(1, 0, 0, 45)
    btn.Position = UDim2.new(0, 0, 0, yPos)
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Text = text
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    return btn
end

-- Función para crear labels de estado
local function createStatusLabel(yPos)
    local label = Instance.new("TextLabel", buttonsFrame)
    label.Size = UDim2.new(1, 0, 0, 25)
    label.Position = UDim2.new(0, 0, 0, yPos)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255, 255, 0)
    label.Font = Enum.Font.Gotham
    label.TextSize = 11
    label.Text = ""
    label.TextXAlignment = Enum.TextXAlignment.Center
    return label
end

-- Botón 1: Inventory AutoSell
local invBtn = createButton(10, "🎒 Toggle Inventory AutoSell", Color3.fromRGB(186, 85, 211))
local invStatus = createStatusLabel(60)
invStatus.Text = "🎒 Inventory AutoSell: ❌ OFF"

-- Botón 2: Summon AutoSell
local summonBtn = createButton(85, "🔮 Toggle Summon AutoSell", Color3.fromRGB(186, 85, 211))
local summonStatus = createStatusLabel(135)
summonStatus.Text = "🔮 Summon AutoSell: ❌ OFF"

-- Botón 3: Sign Frame
local signBtn = createButton(160, "📜 Toggle Sign Frame", Color3.fromRGB(186, 85, 211))
local signStatus = createStatusLabel(210)
signStatus.Text = "📜 Sign Frame: ❌ OFF"

-- Acciones de los botones
invBtn.MouseButton1Click:Connect(function()
    invAutoSellEnabled = not invAutoSellEnabled
    if invAutoSellEnabled then
        invStatus.Text = "🎒 Inventory AutoSell: ✅ ON"
        invStatus.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        invStatus.Text = "🎒 Inventory AutoSell: ❌ OFF"
        invStatus.TextColor3 = Color3.fromRGB(255, 255, 0)
    end
end)

summonBtn.MouseButton1Click:Connect(function()
    summonAutoSellEnabled = not summonAutoSellEnabled
    if summonAutoSellEnabled then
        summonStatus.Text = "🔮 Summon AutoSell: ✅ ON"
        summonStatus.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        summonStatus.Text = "🔮 Summon AutoSell: ❌ OFF"
        summonStatus.TextColor3 = Color3.fromRGB(255, 255, 0)
    end
end)

signBtn.MouseButton1Click:Connect(function()
    signEnabled = not signEnabled
    if signEnabled then
        signStatus.Text = "📜 Sign Frame: ✅ ON"
        signStatus.TextColor3 = Color3.fromRGB(0, 255, 0)
    else
        signStatus.Text = "📜 Sign Frame: ❌ OFF"
        signStatus.TextColor3 = Color3.fromRGB(255, 255, 0)
    end
end)

-- =========================
-- FIRMA (CRÉDITOS)
-- =========================

local signature = Instance.new("TextLabel", mainFrame)
signature.Size = UDim2.new(1, -20, 0, 25)
signature.Position = UDim2.new(0, 10, 1, -35)
signature.BackgroundTransparency = 1
signature.TextColor3 = Color3.fromRGB(128, 128, 128)
signature.Font = Enum.Font.Gotham
signature.TextSize = 10
signature.Text = "⚡ Griff Hub | Visual Toggles"
signature.TextXAlignment = Enum.TextXAlignment.Center

-- =========================
-- FUNCIÓN DE ACTUALIZACIÓN (AutoSell y Sign)
-- =========================

RunService.RenderStepped:Connect(function()
    -- Inventory AutoSell
    local inventory = PlayerGui:FindFirstChild("Inventory", true)
    if inventory then
        local autoSell = inventory:FindFirstChild("AutoSellFrame", true)
        local signFrame = inventory:FindFirstChild("Sign", true)
        if autoSell then 
            autoSell.Visible = invAutoSellEnabled 
        end
        if signFrame then 
            signFrame.Visible = signEnabled 
        end
    end
    
    -- Summon AutoSell
    local summon = PlayerGui:FindFirstChild("Summon", true)
    if summon then
        local autoSell = summon:FindFirstChild("AutoSellFrame", true)
        if autoSell then 
            autoSell.Visible = summonAutoSellEnabled 
        end
    end
end)

print("✅ Griff Hub cargado - Modo visual | AutoSell y Sign toggles")
