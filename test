-- Cargar Amethyst UI
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/J0se-j/My-Lua-Library/refs/heads/main/Booting-the-library.lua"))()

local Window = Library:CreateWindow({
    Name = "Griff Hub v9",
    LoadingTitle = "Griff Hub",
    LoadingSubtitle = "Nightmare + Crazy",
    ToggleUIKeybind = Enum.KeyCode.K,
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "GriffHub",
        FileName = "UserSettings"
    }
})

local MainTab = Window:CreateTab("🌾 AutoFarm", 4483362458)
local NightmareSection = MainTab:CreateSection("🌙 Nightmare")

NightmareSection:CreateToggle({
    Name = "Activar Nightmare",
    Callback = function(Value)
        if Value then
            startNightmare()
        else
            stopNightmare()
        end
    end
})

local CrazySection = MainTab:CreateSection("🌀 Crazy")
CrazySection:CreateToggle({
    Name = "Activar Crazy",
    Callback = function(Value)
        if Value then
            startCrazy()
        else
            stopCrazy()
        end
    end
})

-- Pestaña de Optimización
local OptimizeTab = Window:CreateTab("⚡ Optimizar", 0)
local OptSection = OptimizeTab:CreateSection("Optimizaciones")

OptSection:CreateButton({
    Name = "⚡ Boost FPS",
    Callback = function()
        -- tu código de boost FPS aquí
        Library:Notify("FPS Boost aplicado")
    end
})

OptSection:CreateButton({
    Name = "🔄 Rejoin",
    Callback = function()
        game:GetService("TeleportService"):Teleport(game.PlaceId, game.Players.LocalPlayer)
    end
})
