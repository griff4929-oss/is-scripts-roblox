-- FARM INSANE (con coordenadas específicas)
-- =========================

local function startFarm()
	farmActive = true
	
	task.spawn(function()
		local char = LocalPlayer.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(21.937172, 5.037024, -161.283066))
			task.wait(0.1)
			pcall(function() RS.Events.StartElevator:FireServer("Elevator14") end)
			statusLabel.Text = "✅ TP Completado"
			task.wait(2)
		end
		
		if not farmActive then return end
		
		statusLabel.Text = "▶️ INSANE Activado"
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
		
		-- Coordenadas específicas para INSANE
		local bunnyCFrame = CFrame.new(-75.9942398071289, 85.8345947265625, -93.88702392578125, 1, 0, 0, 0, 1, 0, 0, 0, 1)
		local titanCFrame = CFrame.new(-47.0388031, 90.3418045, -86.8553925, 1, 0, 0, 0, 1, 0, 0, 0, 1)
		
		task.spawn(function()
			while farmActive do
				pcall(function() RS.Events.VoteSkip:FireServer() end)
				task.wait(0.05)
			end
		end)
		
		task.spawn(function()
			while farmActive do
				mejorarUnidad("Large Bunny TV Man")
				mejorarUnidad("Upgraded Titan Cameraman")
				task.wait(0.3)
			end
		end)
		
		statusLabel.Text = "🐰 INSANE - BUNNY"
		timerLabel.Text = "⏱️ Fase: BUNNY"
		timerLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
		
		currentWaitTime = 10
		local bunnyStartTime = tick()
		local bunnyCount = 0
		
		while farmActive and (tick() - bunnyStartTime) < 60 do
			local elapsed = tick() - bunnyStartTime
			local timeLeft = math.max(0, 60 - elapsed)
			timerLabel.Text = "⏱️ BUNNY: " .. math.floor(timeLeft) .. "s"
			spawnTimeLabel.Text = "🐰 Próximo Bunny en " .. currentWaitTime .. "s"
			
			local waited = 0
			while farmActive and waited < currentWaitTime and (tick() - bunnyStartTime) < 60 do
				task.wait(1)
				waited = waited + 1
				if (tick() - bunnyStartTime) < 60 then
					timerLabel.Text = "⏱️ BUNNY: " .. math.floor(60 - (tick() - bunnyStartTime)) .. "s"
					spawnTimeLabel.Text = "🐰 Próximo Bunny en " .. (currentWaitTime - waited) .. "s"
				end
			end
			
			if farmActive and (tick() - bunnyStartTime) < 60 then
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame) end)
				bunnyCount = bunnyCount + 1
				statusLabel.Text = "🐰 INSANE Bunny #" .. bunnyCount
				if currentWaitTime > minWaitTime then
					currentWaitTime = math.max(minWaitTime, currentWaitTime - 1)
				end
				spawnTimeLabel.Text = "🐰 Bunny: " .. currentWaitTime .. "s"
			end
		end
		
		if not farmActive then return end
		
		statusLabel.Text = "🏆 INSANE - TITAN"
		timerLabel.Text = "⏱️ Fase: TITAN"
		timerLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		
		currentWaitTime = 10
		local titanCount = 0
		
		while farmActive do
			spawnTimeLabel.Text = "🏆 Próximo Titan en " .. currentWaitTime .. "s"
			
			local waited = 0
			while farmActive and waited < currentWaitTime do
				task.wait(1)
				waited = waited + 1
				timerLabel.Text = "⏱️ TITAN: INFINITO"
				spawnTimeLabel.Text = "🏆 Próximo Titan en " .. (currentWaitTime - waited) .. "s"
			end
			
			if farmActive then
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Upgraded Titan Cameraman", titanCFrame) end)
				titanCount = titanCount + 1
				statusLabel.Text = "🏆 INSANE Titan #" .. titanCount
				if currentWaitTime > minWaitTime then
					currentWaitTime = math.max(minWaitTime, currentWaitTime - 1)
				end
				spawnTimeLabel.Text = "🏆 Titan: " .. currentWaitTime .. "s"
			end
		end
	end)
end

