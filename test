-- =========================
-- BLOQUEAR SOLO ERRORES DE TEXTO
-- =========================

-- En lugar de manipular TextEvent, usar CoreGui para ocultar notificaciones de error
pcall(function()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        local notifications = playerGui:FindFirstChild("Notifications")
        if notifications then
            -- Ocultar notificaciones de error sin romper nada
            notifications.ChildAdded:Connect(function(child)
                if child:IsA("Frame") and child:FindFirstChild("TextLabel") then
                    local textLabel = child:FindFirstChild("TextLabel")
                    if textLabel and textLabel.Text and string.find(textLabel.Text, "Error") then
                        child:Destroy()
                    end
                end
            end)
        end
    end
end)
