-- =========================
-- SISTEMA DE GUARDADO
-- =========================

local SaveFolder = "GriffHub"
local SaveFile = SaveFolder .. "/Config.json"

local function saveState()
    if not writefile then 
        print("⚠️ Este ejecutor no soporta writefile")
        return 
    end
    if not isfolder(SaveFolder) then 
        pcall(function() makefolder(SaveFolder) end)
    end
    
    local data = {
        nightmareActive = nightmareActive,
        crazyActive = crazyActive
    }
    local success, encoded = pcall(function()
        return game:GetService("HttpService"):JSONEncode(data)
    end)
    if success then
        pcall(function() 
            writefile(SaveFile, encoded) 
            print("💾 Guardado: Nightmare=" .. tostring(nightmareActive) .. ", Crazy=" .. tostring(crazyActive))
        end)
    end
end

local function loadState()
    if not readfile then return false end
    
    local success, content = pcall(function() 
        return readfile(SaveFile) 
    end)
    if success and content and content ~= "" then
        local success2, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(content)
        end)
        if success2 and data then
            nightmareActive = data.nightmareActive or false
            crazyActive = data.crazyActive or false
            print("📂 Cargado: Nightmare=" .. tostring(nightmareActive) .. ", Crazy=" .. tostring(crazyActive))
            return true
        end
    end
    print("📂 No hay configuración previa")
    return false
end

