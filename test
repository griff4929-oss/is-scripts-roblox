					timerLabel2.Text = "⏱️ BUNNY: " .. math.floor(60 - (tick() - bunnyStartTime)) .. "s"
					spawnTimeLabel2.Text = "🐰 Bunny en " .. (currentWaitTime2 - waited) .. "s | 📢 Speakerwoman"
				end
			end
			
			if farm2Active and (tick() - bunnyStartTime) < 60 then
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame2) end)
				bunnyCount = bunnyCount + 1
				
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Upgraded Speakerwoman", speakerwomanCFrame) end)
				speakerwomanCount = speakerwomanCount + 1
				
				statusLabel2.Text = "🐰 Bunny #" .. bunnyCount .. " | 📢 Speakerwoman #" .. speakerwomanCount
				
				if currentWaitTime2 > minWaitTime then
					currentWaitTime2 = math.max(minWaitTime, currentWaitTime2 - 1)
				end
				spawnTimeLabel2.Text = "🐰 Bunny: " .. currentWaitTime2 .. "s | 📢 Speakerwoman: INFINITA"
			end
		end
		
		if not farm2Active then return end
		
		-- FASE 2: MECH (120 segundos)
		statusLabel2.Text = "🤖 Fase 2: MECH (cada 3s) - 120s"
		timerLabel2.Text = "⏱️ Fase: MECH 3s"
		timerLabel2.TextColor3 = Color3.fromRGB(100, 255, 150)
		
		local mechStartTime = tick()
		local mechCount = 0
		
		while farm2Active and (tick() - mechStartTime) < 120 do
			local elapsed = tick() - mechStartTime
			local timeLeft = math.max(0, 120 - elapsed)
			timerLabel2.Text = "⏱️ MECH: " .. math.floor(timeLeft) .. "s"
			spawnTimeLabel2.Text = "🤖 Mech en 3s"
			
			local waited = 0
			while farm2Active and waited < 3 and (tick() - mechStartTime) < 120 do
				task.wait(1)
				waited = waited + 1
				if (tick() - mechStartTime) < 120 then
					timerLabel2.Text = "⏱️ MECH: " .. math.floor(120 - (tick() - mechStartTime)) .. "s"
					spawnTimeLabel2.Text = "🤖 Mech en " .. (3 - waited) .. "s"
				end
			end
			
			if farm2Active and (tick() - mechStartTime) < 120 then
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Mech Cameraman", mechCFrame2) end)
				mechCount = mechCount + 1
				statusLabel2.Text = "🤖 Mech #" .. mechCount
			end
		end
		
		if not farm2Active then return end
		
		-- FASE 3: TITAN
		statusLabel2.Text = "🗑️ Eliminando Bunnies y Speakerwoman extras..."
		venderTodosLosBunnies()
		deleteAllSpeakerwomanExceptOne()
		statusLabel2.Text = "🗑️ Limpieza completada"
		task.wait(1)
		
		if not farm2Active then return end
		
		statusLabel2.Text = "🎬 Fase 3: TITAN CINEMAMAN"
		timerLabel2.Text = "⏱️ Fase: TITAN"
		timerLabel2.TextColor3 = Color3.fromRGB(255, 150, 100)
		
		local titanCount = 0
		
		while farm2Active do
			spawnTimeLabel2.Text = "🎬 Titan en 30s"
			timerLabel2.Text = "⏱️ TITAN: INFINITO"
			
			local waited = 0
			while farm2Active and waited < 30 do
				task.wait(1)
				waited = waited + 1
				spawnTimeLabel2.Text = "🎬 Titan en " .. (30 - waited) .. "s"
			end
			
			if farm2Active then
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Titan Cinemaman", titanCFrame2) end)
				titanCount = titanCount + 1
				statusLabel2.Text = "🎬 Titan #" .. titanCount
			end
		end
	end)
end

