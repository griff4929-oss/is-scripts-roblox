local SaveFileName = "GriffHub_SaveData_" .. LocalPlayer.UserId .. ".json"
local SaveFileName2 = "GriffHub_SaveData2_" .. LocalPlayer.UserId .. ".json"

local function saveState()
	local data = { farmActive = farmActive }
	pcall(function()
		if writefile then
			writefile(SaveFileName, game:GetService("HttpService"):JSONEncode(data))
		end
	end)
end

local function saveState2()
	local data = { farm2Active = farm2Active }
	pcall(function()
		if writefile then
			writefile(SaveFileName2, game:GetService("HttpService"):JSONEncode(data))
		end
	end)
end

local function loadState()
	local success, content = pcall(function()
		if readfile then return readfile(SaveFileName) end
	end)
	if success and content then
		local success2, data = pcall(function()
			return game:GetService("HttpService"):JSONDecode(content)
		end)
		if success2 and data then return data.farmActive or false end
	end
	return false
end

