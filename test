local farm1Btn = createButton(mainFrame, 10, "🌾 Activar Farm 1", Color3.fromRGB(138, 43, 226))
local farm1Status = createStatus(mainFrame, 58, "⏸️ Inactivo")
local farm1Timer = createStatus(mainFrame, 78, "⏱️ --")

local function startFarm1()
	farmActive = true
	
	task.spawn(function()
		local char = LocalPlayer.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.CFrame = CFrame.new(21.937172, 5.037024, -161.283066)
			task.wait(0.1)
			pcall(function() RS.Events.StartElevator:FireServer("Elevator14") end)
			task.wait(2)
		end
		
		local bunnyCFrame = CFrame.new(-25.735321, 86.0418549, -85.5302887)
		local titanCFrame = CFrame.new(-47.0388031, 90.3418045, -86.8553925)
		
		task.spawn(function()
			while farmActive do
				pcall(function() RS.Events.VoteSkip:FireServer() end)
				task.wait(0.05)
			end
		end)
		
		task.spawn(function()
			while farmActive do
				mejorarUnidad("Large Bunny TV Man")
				mejorarUnidad("Upgraded Titan Cameraman")
				task.wait(0.3)
			end
		end)
		
		local bunnyCount = 0
		local titanCount = 0
		local phase = "bunny"
		local phaseStart = tick()
		
		while farmActive do
			if phase == "bunny" and (tick() - phaseStart) >= 60 then
				phase = "titan"
				phaseStart = tick()
				farm1Timer.Text = "⏱️ Fase: TITAN"
			end
			
			if phase == "bunny" then
				local timeLeft = 60 - (tick() - phaseStart)
				farm1Timer.Text = "⏱️ Bunny: " .. math.floor(timeLeft) .. "s"
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame) end)
				bunnyCount = bunnyCount + 1
				farm1Status.Text = "🐰 Bunny #" .. bunnyCount
				task.wait(currentWaitTime)
				if currentWaitTime > minWaitTime then currentWaitTime = math.max(minWaitTime, currentWaitTime - 1) end
			else
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Upgraded Titan Cameraman", titanCFrame) end)
				titanCount = titanCount + 1
				farm1Status.Text = "🏆 Titan #" .. titanCount
				farm1Timer.Text = "⏱️ Titan: INFINITO"
				task.wait(currentWaitTime)
				if currentWaitTime > minWaitTime then currentWaitTime = math.max(minWaitTime, currentWaitTime - 1) end
			end
		end
	end)
end

