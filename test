-- FUNCIÓN PARA ACTUALIZAR EL ORO EN LA GUI (PERSISTENTE)
-- =========================

local function updateGoldValue()
    if not goldDisplay then return end
    
    local function actualizar()
        local goldValue = LocalPlayer:FindFirstChild("Gold")
        if goldValue and goldDisplay then
            goldDisplay.Text = "💰 $" .. goldValue.Value
        elseif goldDisplay then
            goldDisplay.Text = "💰 $0"
        end
    end
    
    local function conectarOro()
        local gold = LocalPlayer:FindFirstChild("Gold")
        if gold then
            local connection
            connection = gold.Changed:Connect(function(newValue)
                if goldDisplay then
                    goldDisplay.Text = "💰 $" .. newValue
                end
            end)
            
            gold.AncestryChanged:Connect(function()
                if not gold.Parent then
                    if connection then connection:Disconnect() end
                    task.wait(0.1)
                    conectarOro()
                end
            end)
            
            actualizar()
        else
            LocalPlayer.ChildAdded:Connect(function(child)
                if child.Name == "Gold" then
                    conectarOro()
                end
            end)
            actualizar()
        end
    end
    
    conectarOro()
end

