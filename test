local function startFarm1()
	farmActive = true
	
	task.spawn(function()
		local char = LocalPlayer.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(21.937172, 5.037024, -161.283066))
			task.wait(0.1)
			pcall(function() RS.Events.StartElevator:FireServer("Elevator14") end)
			statusLabel1.Text = "✅ TP Completado"
			task.wait(2)
		end
		
		if not farmActive then return end
		
		statusLabel1.Text = "▶️ Farm 1 Activado"
		statusLabel1.TextColor3 = Color3.fromRGB(0, 255, 0)
		
		local bunnyCFrame = CFrame.new(-25.735321, 86.0418549, -85.5302887, 1, 0, 0, 0, 1, 0, 0, 0, 1)
		local titanCFrame = CFrame.new(-47.0388031, 90.3418045, -86.8553925, 1, 0, 0, 0, 1, 0, 0, 0, 1)
		
		task.spawn(function()
			while farmActive do
				pcall(function() RS.Events.VoteSkip:FireServer() end)
				task.wait(0.05)
			end
		end)
		
		task.spawn(function()
			while farmActive do
				mejorarUnidad("Large Bunny TV Man")
				mejorarUnidad("Upgraded Titan Cameraman")
				task.wait(0.3)
			end
		end)
		
		statusLabel1.Text = "🐰 Farm 1 - BUNNY"
		timerLabel1.Text = "⏱️ Fase: BUNNY"
		timerLabel1.TextColor3 = Color3.fromRGB(255, 200, 0)
		
		currentWaitTime = 16
		local bunnyStartTime = tick()
		local bunnyCount = 0
		
		while farmActive and (tick() - bunnyStartTime) < 60 do
			local elapsed = tick() - bunnyStartTime
			local timeLeft = math.max(0, 60 - elapsed)
			timerLabel1.Text = "⏱️ BUNNY: " .. math.floor(timeLeft) .. "s"
			spawnTimeLabel1.Text = "🐰 Próximo Bunny en " .. currentWaitTime .. "s"
			
			local waited = 0
			while farmActive and waited < currentWaitTime and (tick() - bunnyStartTime) < 60 do
				task.wait(1)
				waited = waited + 1
				elapsed = tick() - bunnyStartTime
				if (tick() - bunnyStartTime) < 60 then
					local timeLeft = math.max(0, 60 - elapsed)
					timerLabel1.Text = "⏱️ BUNNY: " .. math.floor(timeLeft) .. "s"
					spawnTimeLabel1.Text = "🐰 Próximo Bunny en " .. (currentWaitTime - waited) .. "s"
				end
			end
			
			if farmActive and (tick() - bunnyStartTime) < 60 then
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Large Bunny TV Man", bunnyCFrame) end)
				bunnyCount = bunnyCount + 1
				statusLabel1.Text = "🐰 Farm 1 Bunny #" .. bunnyCount
				if currentWaitTime > minWaitTime then
					currentWaitTime = math.max(minWaitTime, currentWaitTime - 1)
				end
				spawnTimeLabel1.Text = "🐰 Bunny: " .. currentWaitTime .. "s"
			end
		end
		
		if not farmActive then return end
		
		statusLabel1.Text = "🏆 Farm 1 - TITAN"
		timerLabel1.Text = "⏱️ Fase: TITAN"
		timerLabel1.TextColor3 = Color3.fromRGB(255, 100, 100)
		
		currentWaitTime = 16
		local titanCount = 0
		
		while farmActive do
			spawnTimeLabel1.Text = "🏆 Próximo Titan en " .. currentWaitTime .. "s"
			
			local waited = 0
			while farmActive and waited < currentWaitTime do
				task.wait(1)
				waited = waited + 1
				timerLabel1.Text = "⏱️ TITAN: INFINITO"
				spawnTimeLabel1.Text = "🏆 Próximo Titan en " .. (currentWaitTime - waited) .. "s"
			end
			
			if farmActive then
				pcall(function() RS.Functions.SpawnTower:InvokeServer("Upgraded Titan Cameraman", titanCFrame) end)
				titanCount = titanCount + 1
				statusLabel1.Text = "🏆 Farm 1 Titan #" .. titanCount
				if currentWaitTime > minWaitTime then
					currentWaitTime = math.max(minWaitTime, currentWaitTime - 1)
				end
				spawnTimeLabel1.Text = "🏆 Titan: " .. currentWaitTime .. "s"
			end
		end
	end)
end

