function cacheLink()
    if cachedTime + (10*60) < fOsTime() then
        local response = fRequest({ Url = host .. "/public/start", Method = "POST", Body = lEncode({ service = service, identifier = lDigest(fGetHwid()) }), Headers = { ["Content-Type"] = "application/json" } });
        if response.StatusCode == 200 then
            local decoded = lDecode(response.Body);
            if decoded.success == true then cachedLink = decoded.data.url; cachedTime = fOsTime(); return true, cachedLink;
            else onMessage(decoded.message); return false, decoded.message; end
        elseif response.StatusCode == 429 then
            local msg = "you are being rate limited, please wait 20 seconds and try again.";
            onMessage(msg); return false, msg;
        end
        local msg = "Failed to cache link.";
        onMessage(msg); return false, msg;
    else return true, cachedLink; end
end
