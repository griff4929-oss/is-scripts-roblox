-- Coloca este script en FuseMachine (LocalScript)

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local RemoteEvents = ReplicatedStorage.Game.Events
local Functions = ReplicatedStorage.Game.Functions

-- ============================================
-- 🔥 REFERENCIAS A LA UI
-- ============================================

local FuseMachine = script.Parent

-- Contenedor de slots (Tower)
local TowerContainer = FuseMachine:FindFirstChild("Tower")
local Slots = {}

if TowerContainer then
	for _, child in ipairs(TowerContainer:GetChildren()) do
		if child.Name and string.match(child.Name, "^Slot%d+$") then
			local slotNumber = tonumber(string.match(child.Name, "%d+"))
			if slotNumber then
				Slots[slotNumber] = child
				print("✅ Slot encontrado:", slotNumber)
			end
		end
	end
end

local sortedSlots = {}
for i = 1, 4 do
	sortedSlots[i] = Slots[i]
	if not Slots[i] then
		print("⚠️ Slot", i, "no encontrado")
	end
end

-- 🔥 INVENTARIO DENTRO DE FUSEMACHINE (se llama InventoryFuse)
local InventoryFrame = FuseMachine:FindFirstChild("InventoryFuse")
print("📦 InventoryFuse encontrado:", InventoryFrame ~= nil)

-- Si no está dentro, buscar en otro lugar
if not InventoryFrame then
	local parent = FuseMachine.Parent
	while parent do
		InventoryFrame = parent:FindFirstChild("InventoryFuse") or parent:FindFirstChild("Inventory")
		if InventoryFrame then break end
		parent = parent.Parent
	end
end

-- Obtener componentes del inventario
local ScrollFrame = nil
local List = InventoryFrame and InventoryFrame:FindFirstChild("List")
if List then
	ScrollFrame = List:FindFirstChild("ScrollingFrame")
end

print("📋 ScrollFrame encontrado:", ScrollFrame ~= nil)

-- Panel de posibles fusiones
local FusionsPanel = FuseMachine:FindFirstChild("Fusions")
local PossibleFusions = FusionsPanel and FusionsPanel:FindFirstChild("PossibleFusions")
local TitleLabel = FusionsPanel and FusionsPanel:FindFirstChild("Title")

-- Botón de fusión (si existe fuera de los slots)
local FuseButton = FuseMachine:FindFirstChild("FuseButton") or FuseMachine:FindFirstChild("ADDTOwer")

-- ============================================
-- 🔥 VARIABLES
-- ============================================

local selectedTowerIds = {nil, nil, nil, nil}
local selectedTowerData = {nil, nil, nil, nil}
local isFusing = false
local pendingSlot = nil
local fusionCost = 1000 -- Costo por defecto

-- Colores por rareza
local RARITY_COLORS = {
	["Basic"] = Color3.fromRGB(128, 128, 128),
	["Uncommon"] = Color3.fromRGB(0, 255, 0),
	["Rare"] = Color3.fromRGB(0, 150, 255),
	["Epic"] = Color3.fromRGB(163, 53, 238),
	["Legendary"] = Color3.fromRGB(255, 170, 0),
	["Mythic"] = Color3.fromRGB(255, 50, 50),
}

local RARITY_ORDER = {
	["Basic"] = 1,
	["Uncommon"] = 2,
	["Rare"] = 3,
	["Epic"] = 4,
	["Legendary"] = 5,
	["Mythic"] = 6,
}

-- ============================================
-- 🔥 FUNCIONES DE UI
-- ============================================

local function ShowInventory(show)
	if not InventoryFrame then 
		print("❌ No se puede mostrar inventario")
		return 
	end
	InventoryFrame.Visible = show
	print("📂 Inventario visible:", show)
end

local function UpdateSlotVisual(slotIndex, towerData)
	local slot = sortedSlots[slotIndex]
	if not slot then return end

	local towerNameLabel = slot:FindFirstChild("TowerName")
	local shinyIcon = slot:FindFirstChild("ShinyIcon")
	local viewportFrame = slot:FindFirstChild("ViewportFrame")
	local priceLabel = slot:FindFirstChild("price")

	if towerData then
		if towerNameLabel then
			towerNameLabel.Text = towerData.name or "???"
			towerNameLabel.Visible = true
		end

		if shinyIcon then
			shinyIcon.Visible = towerData.Shiny == true
		end

		local rarity = towerData.rarity or "Basic"
		if viewportFrame then
			viewportFrame.BackgroundColor3 = RARITY_COLORS[rarity] or Color3.fromRGB(50, 50, 50)
			viewportFrame.BackgroundTransparency = 0.5
		end

		if priceLabel then
			priceLabel.Visible = false
		end

		slot.BackgroundTransparency = 0.5
		TweenService:Create(slot, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
	else
		if towerNameLabel then
			towerNameLabel.Text = "Empty"
			towerNameLabel.Visible = true
		end

		if shinyIcon then
			shinyIcon.Visible = false
		end

		if viewportFrame then
			viewportFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
			viewportFrame.BackgroundTransparency = 0.5
		end

		if priceLabel then
			priceLabel.Visible = true
			priceLabel.Text = "➕"
			priceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		end
	end
end

-- ============================================
-- 🔥 ACTUALIZAR POSIBLES RESULTADOS
-- ============================================

local function UpdatePossibleResults()
	if not PossibleFusions then return end

	for _, child in ipairs(PossibleFusions:GetChildren()) do
		if child:IsA("Frame") and child.Name ~= "Template" and child.Name ~= "Title" then
			child:Destroy()
		end
	end

	local template = PossibleFusions:FindFirstChild("Template")
	if not template then return end

	local totalRarity = 0
	local totalCount = 0
	local rarityList = {}

	for i = 1, 4 do
		local towerData = selectedTowerData[i]
		if towerData and towerData.rarity then
			local rarityValue = RARITY_ORDER[towerData.rarity] or 1
			totalRarity = totalRarity + rarityValue
			totalCount = totalCount + 1
			table.insert(rarityList, towerData.rarity)
		end
	end

	local averageRarity = totalCount > 0 and (totalRarity / totalCount) or 0

	if TitleLabel then
		if totalCount == 4 then
			local tier = math.floor(averageRarity)
			tier = math.clamp(tier, 1, 5)
			local tierNames = { "⭐ Baja", "⭐⭐ Media-Baja", "⭐⭐⭐ Media", "⭐⭐⭐⭐ Media-Alta", "⭐⭐⭐⭐⭐ Alta" }
			TitleLabel.Text = "📊 " .. string.format("%.1f", averageRarity) .. " " .. tierNames[tier]
		else
			TitleLabel.Text = "📊 " .. totalCount .. "/4 unidades"
		end
	end

	if totalCount < 4 then return end

	local tier = math.floor(averageRarity)
	tier = math.clamp(tier, 1, 5)

	local possibleRewards = {
		[1] = {{name="Large Speakerman", chance=40}, {name="TV Woman", chance=35}, {name="Large Cameraman", chance=25}},
		[2] = {{name="Titan Speakerman", chance=35}, {name="Titan Cameraman", chance=35}, {name="Titan TV Man", chance=30}},
		[3] = {{name="Giant Speakerman", chance=40}, {name="Lucky Speakerman", chance=35}, {name="Titan x2", chance=25}},
		[4] = {{name="Leprechaun Cameraman", chance=35}, {name="Elf Cameraman", chance=35}, {name="Giant Speakerman x2", chance=30}},
		[5] = {{name="Leprechaun Cameraman x2", chance=40}, {name="Elf Cameraman x2", chance=35}, {name="Mythic Especial", chance=25}},
	}

	for _, reward in ipairs(possibleRewards[tier]) do
		local rewardFrame = template:Clone()
		rewardFrame.Name = reward.name
		rewardFrame.Visible = true

		local rewardTitle = rewardFrame:FindFirstChild("Title")
		if rewardTitle then
			rewardTitle.Text = reward.name
		end

		local rewardChance = rewardFrame:FindFirstChild("Chance")
		if rewardChance then
			rewardChance.Text = reward.chance .. "%"
		end

		rewardFrame.Parent = PossibleFusions
	end
end

-- ============================================
-- 🔥 MANEJAR SLOTS
-- ============================================

local function OpenInventoryForSlot(slotIndex)
	if isFusing then return end
	if selectedTowerIds[slotIndex] then return end

	pendingSlot = slotIndex
	ShowInventory(true)

	local slot = sortedSlots[slotIndex]
	local priceLabel = slot and slot:FindFirstChild("price")
	if priceLabel then
		priceLabel.Text = "🔍"
		priceLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
	end
end

local function AddToSlot(slotIndex, towerData, towerId)
	if not slotIndex then return false, "Slot inválido" end
	if towerData.Starter then return false, "❌ Starter no fusionable" end
	if towerData.Locked then return false, "🔒 Torre bloqueada" end
	if selectedTowerIds[slotIndex] then return false, "❌ Slot ocupado" end

	selectedTowerIds[slotIndex] = towerId
	selectedTowerData[slotIndex] = towerData
	UpdateSlotVisual(slotIndex, towerData)
	UpdatePossibleResults()

	return true, "✅ Añadida"
end

local function RemoveFromSlot(slotIndex)
	if not selectedTowerIds[slotIndex] then return false end

	selectedTowerIds[slotIndex] = nil
	selectedTowerData[slotIndex] = nil
	UpdateSlotVisual(slotIndex, nil)
	UpdatePossibleResults()

	return true
end

-- ============================================
-- 🔥 FUSIÓN
-- ============================================

local function PerformFusion()
	if isFusing then return end

	for i = 1, 4 do
		if not selectedTowerIds[i] then
			local slot = sortedSlots[i]
			local priceLabel = slot and slot:FindFirstChild("price")
			if priceLabel then
				priceLabel.Text = "❌"
				priceLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
				task.delay(1.5, function()
					if priceLabel and not selectedTowerIds[i] then
						priceLabel.Text = "➕"
						priceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
					end
				end)
			end
			return
		end
	end

	isFusing = true

	-- Efecto de carga
	for i = 1, 4 do
		local slot = sortedSlots[i]
		if slot then
			TweenService:Create(slot, TweenInfo.new(0.3), {BackgroundTransparency = 0.3}):Play()
		end
	end

	task.wait(0.5)

	-- Llamar al servidor
	local success, result = pcall(function()
		return RemoteEvents.FuseUnits:InvokeServer(selectedTowerIds)
	end)

	if success and result and result.Success then
		-- Limpiar slots
		for i = 1, 4 do
			selectedTowerIds[i] = nil
			selectedTowerData[i] = nil
			UpdateSlotVisual(i, nil)
		end

		-- Mostrar éxito
		for i = 1, 4 do
			local slot = sortedSlots[i]
			local priceLabel = slot and slot:FindFirstChild("price")
			if priceLabel then
				priceLabel.Text = "✓"
				priceLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
				task.delay(2, function()
					if priceLabel and not selectedTowerIds[i] then
						priceLabel.Text = "➕"
						priceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
					end
				end)
			end
		end
		
		-- Mostrar mensaje del resultado
		if result.Message then
			print("🎉 " .. result.Message)
		end
	else
		-- Mostrar error
		local errorMsg = result and result.Message or "Error en la fusión"
		print("❌ " .. errorMsg)
		
		for i = 1, 4 do
			local slot = sortedSlots[i]
			local priceLabel = slot and slot:FindFirstChild("price")
			if priceLabel then
				priceLabel.Text = "❌"
				priceLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
				task.delay(2, function()
					if priceLabel then
						priceLabel.Text = "➕"
						priceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
					end
				end)
			end
		end
	end

	isFusing = false
	UpdatePossibleResults()
end

local function CheckAutoFuse()
	local allFilled = true
	for i = 1, 4 do
		if not selectedTowerIds[i] then
			allFilled = false
			break
		end
	end

	if allFilled and not isFusing then
		task.wait(0.8)
		PerformFusion()
	end
end

-- ============================================
-- 🔥 CONECTAR SLOTS
-- ============================================

for i = 1, 4 do
	local slot = sortedSlots[i]
	if slot then
		slot.Activated:Connect(function()
			if selectedTowerIds[i] then
				RemoveFromSlot(i)
			else
				OpenInventoryForSlot(i)
			end
		end)
	end
end

-- ============================================
-- 🔥 CONECTAR BOTÓN DE FUSIÓN (si existe)
-- ============================================

if FuseButton then
	FuseButton.Activated:Connect(PerformFusion)
end

-- ============================================
-- 🔥 CONECTAR INVENTARIO
-- ============================================

local function GetTowerDataFromButton(towerButton)
	local towerData = {
		name = towerButton.Name,
		rarity = towerButton:GetAttribute("Rarity") or "Basic",
		Shiny = towerButton:FindFirstChild("ShinyIcon") and towerButton.ShinyIcon.Visible or false,
		Locked = towerButton:FindFirstChild("LockIcon") and towerButton.LockIcon.Visible or false,
		Starter = (towerButton.LayoutOrder == 999999999),
		UniqueID = towerButton:GetAttribute("UniqueID") or towerButton:GetAttribute("ID") or towerButton.Name
	}
	return towerData
end

local function AddTowerListener(towerButton)
	if not towerButton:IsA("ImageButton") then return end
	if towerButton.Name == "Example" then return end
	if towerButton:GetAttribute("FusionListener") then return end
	
	towerButton:SetAttribute("FusionListener", true)
	
	towerButton.Activated:Connect(function()
		print("🖱️ Click en torre:", towerButton.Name)
		
		if pendingSlot then
			local towerData = GetTowerDataFromButton(towerButton)
			local towerId = towerData.UniqueID
			
			local success, message = AddToSlot(pendingSlot, towerData, towerId)
			
			local originalColor = towerButton.BackgroundColor3
			if success then
				print("   ✅ Torre añadida al slot", pendingSlot)
				towerButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
				task.delay(0.2, function()
					towerButton.BackgroundColor3 = originalColor
				end)
				
				ShowInventory(false)
				
				local slot = sortedSlots[pendingSlot]
				local priceLabel = slot and slot:FindFirstChild("price")
				if priceLabel then
					priceLabel.Text = "✓"
					priceLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
					task.delay(0.5, function()
						if priceLabel and selectedTowerIds[pendingSlot] then
							priceLabel.Visible = false
						end
					end)
				end
				
				CheckAutoFuse()
			else
				print("   ❌ Error:", message)
				towerButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
				task.delay(0.2, function()
					towerButton.BackgroundColor3 = originalColor
				end)
				
				local slot = sortedSlots[pendingSlot]
				local priceLabel = slot and slot:FindFirstChild("price")
				if priceLabel then
					priceLabel.Text = "❌"
					priceLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
					task.delay(1.5, function()
						if priceLabel and not selectedTowerIds[pendingSlot] then
							priceLabel.Text = "➕"
							priceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
						end
					end)
				end
			end
			
			pendingSlot = nil
		else
			print("   ⚠️ No hay slot pendiente")
		end
	end)
end

local function ConnectInventory()
	if not ScrollFrame then
		print("❌ ScrollFrame no encontrado")
		return false
	end
	
	print("🔄 Conectando inventario...")
	local count = 0
	
	for _, child in ipairs(ScrollFrame:GetChildren()) do
		if child:IsA("ImageButton") and child.Name ~= "Example" then
			AddTowerListener(child)
			count = count + 1
		end
	end
	
	print("   ✅ Conectadas", count, "torres")
	
	ScrollFrame.ChildAdded:Connect(function(child)
		task.wait(0.1)
		if child:IsA("ImageButton") and child.Name ~= "Example" then
			AddTowerListener(child)
			print("   ➕ Nueva torre conectada:", child.Name)
		end
	end)
	
	return true
end

-- ============================================
-- 🔥 CERRAR INVENTARIO
-- ============================================

local CloseButton = InventoryFrame and InventoryFrame:FindFirstChild("CloseButton")
if CloseButton then
	CloseButton.Activated:Connect(function()
		ShowInventory(false)
		if pendingSlot then
			local slot = sortedSlots[pendingSlot]
			local priceLabel = slot and slot:FindFirstChild("price")
			if priceLabel then
				priceLabel.Text = "➕"
				priceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
			end
			pendingSlot = nil
		end
	end)
end

-- ============================================
-- 🔥 INICIALIZAR
-- ============================================

-- Esperar a que el inventario cargue
local function WaitForInventory()
	local attempts = 0
	while attempts < 30 do
		if ScrollFrame then
			local hasTowers = false
			for _, child in ipairs(ScrollFrame:GetChildren()) do
				if child:IsA("ImageButton") and child.Name ~= "Example" then
					hasTowers = true
					break
				end
			end
			
			if hasTowers then
				ConnectInventory()
				return true
			end
		end
		attempts = attempts + 1
		task.wait(0.5)
		print("   Esperando torres... (" .. attempts .. "/30)")
	end
	
	print("⚠️ No se encontraron torres en el inventario")
	return false
end

WaitForInventory()

-- Inicializar slots
for i = 1, 4 do
	UpdateSlotVisual(i, nil)
end
UpdatePossibleResults()

if InventoryFrame then
	InventoryFrame.Visible = false
end

-- Escuchar eventos del servidor
if RemoteEvents.FusionFinished then
	RemoteEvents.FusionFinished.OnClientEvent:Connect(function(success, message, result)
		if success then
			print("🎉 " .. message)
			-- Actualizar inventario después de la fusión
			pcall(function()
				Functions.GetInventoryData:InvokeServer()
			end)
		end
	end)
end

